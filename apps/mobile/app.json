{
  "expo": {
    "name": "Planova",
    "slug": "mimar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "mimar",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.mimar.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1B2E"
      }
    },
    "ios": {
      "bundleIdentifier": "com.mimar.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Proje notlarına görsel eklemek için galeri erişimi gereklidir.",
          "cameraPermission": "Proje notlarına fotoğraf çekmek için kamera erişimi gereklidir."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ]
  }
}
