{
  "expo": {
    "name": "Planova",
    "slug": "mimar-app",
    "owner": "celikler",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "mimar",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.mimar.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1B2E"
      }
    },
    "ios": {
      "bundleIdentifier": "com.mimar.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Proje notlarına görsel eklemek için galeri erişimi gereklidir.",
          "cameraPermission": "Proje notlarına fotoğraf çekmek için kamera erişimi gereklidir."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.863980504433-tohah1oj5kdkmt8hbus81keuqp8vt0vs"
        }
      ],
      "./plugins/withGoogleSignInModularHeaders.js",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "36fccdcf-f7cf-4d48-978c-03998a7e6a23"
      }
    }
  }
}
